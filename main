#include <iostream>
using namespace std;

int main() {

int cookies;

double servings;
double calories;

cout << "how many cookies have you eaten";

cin >> cookies;

const int cookies_per_serving = 5;
const int calories_per_serving = 160;

servings = static_cast<double>(cookies)/cookies_per_serving;
calories = servings*calories_per_serving;

cout << "you consumed";
cout << calories;
cout << "calories"; 
cout << servings;
cout << "servings";

return 0;
}
